# =============================================================================
# Napkin Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] have no default and must be set.
# =============================================================================

# --- App ---
APP_ENV=development                  # development | staging | production
APP_DEBUG=false                      # Enable debug mode
APP_HOST=0.0.0.0                     # Server bind address
APP_PORT=8000                        # Server bind port
APP_SECRET_KEY=your-secret-key-here  # [REQUIRED] Signing key for tokens — no default

# --- Database (Supabase) ---
SUPABASE_URL=https://your-project.supabase.co          # [REQUIRED] Supabase project URL
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...              # [REQUIRED] Supabase anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...      # [REQUIRED] Supabase service-role key (admin)
SUPABASE_JWT_SECRET=                                     # JWT secret for token verification

# --- LLM (Anthropic Claude) ---
ANTHROPIC_API_KEY=sk-ant-...         # Anthropic API key
LLM_DEFAULT_PROVIDER=anthropic       # LLM provider (currently only "anthropic")
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514  # Default Claude model
LLM_TEMPERATURE=0.1                  # LLM sampling temperature (0.0–1.0)

# --- Embeddings (local HuggingFace) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2    # HuggingFace sentence-transformer model
EMBEDDING_DIMENSIONS=384             # Vector dimensions (must match model)

# --- Redis ---
REDIS_URL=redis://localhost:6379/0   # Redis connection URL (caching & Celery broker)

# --- GitHub (optional) ---
GITHUB_APP_ID=                       # GitHub App ID
GITHUB_APP_PRIVATE_KEY=              # GitHub App private key (PEM)
GITHUB_PERSONAL_ACCESS_TOKEN=        # GitHub personal access token

# --- Observability ---
SENTRY_DSN=                          # Sentry DSN for error tracking
LOG_LEVEL=INFO                       # Log level (DEBUG | INFO | WARNING | ERROR)

# --- Rate Limits ---
RATE_LIMIT_PER_MINUTE=60             # Max API requests per minute
MAX_FEEDBACK_ITEMS_PER_SESSION=500   # Max feedback items per session
MAX_SESSION_DURATION_MINUTES=60      # Max session duration (minutes)
